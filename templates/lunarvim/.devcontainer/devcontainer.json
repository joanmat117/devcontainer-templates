{
    "name": "LunarVim Development Environment",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "."
    },
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools",
                "rust-lang.rust-analyzer"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.fontFamily": "FiraCode Nerd Font"
            }
        }
    },
    "remoteUser": "lunaruser",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/lunaruser/.gitconfig,type=bind,consistency=cached"
    ],
    "postCreateCommand": "sudo chown -R lunaruser:lunaruser /workspace && echo '✅ LunarVim installed. Use: lvim'",
    "postAttachCommand": "echo '🚀 Environment ready - Working directory: $(pwd) - LunarVim: lvim, Neovim: nvim'"
}
